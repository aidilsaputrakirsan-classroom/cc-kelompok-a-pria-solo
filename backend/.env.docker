# ============================================================
# Docker network settings (Modul 6)
# ============================================================

# Use container name "db" as hostname inside Docker network.
DATABASE_URL=mysql+pymysql://clouduser:cloudpass@db:3306/cloudapp
DB_HOST=db
DB_PORT=3306
MYSQL_USER=clouduser
MYSQL_PASSWORD=cloudpass
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=cloudapp

# Optional wait-for-db behavior
DB_WAIT_RETRIES=60
DB_WAIT_SLEEP=2

# Existing backend env placeholders
AZURE_OCR_PROJESSAI_KEY=
AZURE_OCR_PROJESSAI_ENDPOINT=
AZURE_DI_PROJESSAI_ENDPOINT=
AZURE_DI_PROJESSAI_KEY=
TEMP_STORAGE=./temp
OPENAI_API_KEY=
CHUNK_SIZE=10

# CORS for browser origins (frontend host)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:3000,http://localhost:3000
