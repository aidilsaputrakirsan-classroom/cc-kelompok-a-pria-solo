# Salin ke .env.docker:  cp .env.docker.example .env.docker
# Jangan commit .env.docker (berisi secret).

AZURE_OCR_PROJESSAI_KEY=""
AZURE_OCR_PROJESSAI_ENDPOINT=""
AZURE_DI_PROJESSAI_ENDPOINT=""
AZURE_DI_PROJESSAI_KEY=""
TEMP_STORAGE=/tmp/pria-storage
OPENAI_API_KEY=""
CHUNK_SIZE=10

# Origin browser (gateway Modul 12)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:8080

# MySQL service name di Compose = db
DATABASE_URL=mysql+pymysql://clouduser:CHANGE_ME@db:3306/cloudapp
DB_HOST=db
DB_PORT=3306
MYSQL_USER=clouduser
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=cloudapp
DB_WAIT_RETRIES=60
DB_WAIT_SLEEP=2

# Modul 14 — structured logging
SERVICE_NAME=document-service
LOG_LEVEL=INFO
