AZURE_OCR_PROJESSAI_KEY=""
AZURE_OCR_PROJESSAI_ENDPOINT=""
AZURE_DI_PROJESSAI_ENDPOINT=""
AZURE_DI_PROJESSAI_KEY=""
TEMP_STORAGE=""
OPENAI_API_KEY=""

# CORS: origin halaman Laravel di browser (port 8000). API FastAPI biasanya di 8001 — jangan tukar dengan origin ini.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ============================================================
# Optional Docker network settings (Modul 6)
# ============================================================
# Enable these when backend runs in Docker network with MySQL container.
DATABASE_URL=mysql+pymysql://clouduser:cloudpass@db:3306/cloudapp
DB_HOST=db
DB_PORT=3306
MYSQL_USER=clouduser
MYSQL_PASSWORD=cloudpass
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=cloudapp
DB_WAIT_RETRIES=60
DB_WAIT_SLEEP=2