# Salin ke .env.docker:  cp .env.docker.example .env.docker
# APP_KEY di bawah untuk demo lokal Docker saja — ganti untuk production.

APP_NAME="PRIA Solo"
APP_ENV=local
APP_KEY=base64:2aor63YzF6EHXCZX7CvRrVNC4JRdcZCl3UkqZ5vwssE=
APP_DEBUG=true
APP_URL=http://localhost:8080

# FastAPI via API Gateway (Modul 12)
URL_VM_PYTHON=http://gateway/api/python

LOG_CHANNEL=json_stdout
LOG_STACK_CHANNEL=json_stdout
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cloudapp
DB_USERNAME=clouduser
DB_PASSWORD=CHANGE_ME

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
